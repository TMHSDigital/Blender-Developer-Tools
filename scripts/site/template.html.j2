<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ plugin.displayName }} — Blender Python that actually runs</title>
  <meta name="description" content="{{ plugin.description }}" />
  {% if site.canonical %}<link rel="canonical" href="{{ site.canonical }}" />{% endif %}
  {% if site.favicon %}<link rel="icon" href="{{ site.favicon }}" />{% endif %}
  <meta name="theme-color" content="#1a1b1e" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ plugin.displayName }} — Blender Python that actually runs" />
  <meta property="og:description" content="{{ plugin.description }}" />
  {% if site.canonical %}<meta property="og:url" content="{{ site.canonical }}" />{% endif %}
  {% set og_image = site.ogImage | default('', true) %}
  {% if og_image %}<meta property="og:image" content="{{ og_image }}" />{% endif %}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ plugin.displayName }} — Blender Python that actually runs" />
  <meta name="twitter:description" content="{{ plugin.description }}" />
  {% if og_image %}<meta name="twitter:image" content="{{ og_image }}" />{% endif %}
  <style>
    /* ---- fonts (self-hosted, copied to docs/fonts/ by build_site.py) ---- */
    @font-face { font-family: 'Barlow Condensed'; font-weight: 500; font-display: swap;
      src: url('fonts/barlow-condensed-500.woff2') format('woff2'); }
    @font-face { font-family: 'Barlow Condensed'; font-weight: 600; font-display: swap;
      src: url('fonts/barlow-condensed-600.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-weight: 400; font-display: swap;
      src: url('fonts/inter-regular.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-weight: 500; font-display: swap;
      src: url('fonts/inter-medium.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-weight: 700; font-display: swap;
      src: url('fonts/inter-bold.woff2') format('woff2'); }
    @font-face { font-family: 'JetBrains Mono'; font-weight: 400; font-display: swap;
      src: url('fonts/jetbrains-mono-regular.woff2') format('woff2'); }

    /* ---- tokens: Blender's own UI grays; selection orange is THE accent;
           axis colors appear only in the gizmo and the grid origin lines ---- */
    :root {
      --bg: #1a1b1e; --panel: #222327; --panel-2: #2a2b30; --border: #3a3b40;
      --text: #e8e9eb; --dim: #9698a0;
      --select: #ff8c19;
      --ax-x: #ff3352; --ax-y: #8bdc00; --ax-z: #2890ff;
      --ok: #6dc96d;
      --font-display: 'Barlow Condensed', 'Arial Narrow', sans-serif;
      --font-body: 'Inter', -apple-system, 'Segoe UI', sans-serif;
      --font-mono: 'JetBrains Mono', ui-monospace, Consolas, monospace;
      --maxw: 1060px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: var(--font-body);
      line-height: 1.6; font-size: 16px; -webkit-font-smoothing: antialiased; }
    a { color: var(--text); text-decoration: none; }
    :focus-visible { outline: 2px solid var(--select); outline-offset: 2px; border-radius: 2px; }
    ::selection { background: color-mix(in srgb, var(--select) 40%, transparent); }
    .skip { position: absolute; left: -999px; top: 0; background: var(--select); color: #1a1b1e;
      padding: 0.5rem 1rem; border-radius: 4px; z-index: 30; font-weight: 500; }
    .skip:focus { left: 0.5rem; top: 0.5rem; }

    /* HUD vocabulary: small mono labels, everywhere */
    .hud { font-family: var(--font-mono); font-size: 0.6875rem; letter-spacing: 0.04em;
      color: var(--dim); text-transform: uppercase; }

    /* ---- topbar: Blender's topbar ---- */
    .topbar { position: sticky; top: 0; z-index: 20; background: color-mix(in srgb, var(--panel) 92%, transparent);
      backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
    .topbar-inner { max-width: var(--maxw); margin: 0 auto; display: flex; align-items: center;
      gap: 1rem; padding: 0 1.25rem; height: 46px; }
    .brand { display: flex; align-items: center; gap: 0.6rem; font-weight: 700; font-size: 0.9rem; white-space: nowrap; }
    .brand-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--select); flex-shrink: 0; }
    .mode-chip { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--dim);
      border: 1px solid var(--border); border-radius: 3px; padding: 0.1rem 0.5rem; white-space: nowrap; }
    .topnav { margin-left: auto; display: flex; gap: 1.1rem; list-style: none; align-items: center; }
    .topnav a { color: var(--dim); font-size: 0.8125rem; font-weight: 500; transition: color 0.15s; }
    .topnav a:hover { color: var(--select); }

    /* ---- hero: the viewport ---- */
    .stage { max-width: var(--maxw); margin: 1.25rem auto 0; padding: 0 1.25rem; }
    .viewport { position: relative; border: 1px solid var(--border); border-radius: 6px;
      background: linear-gradient(180deg, #212226 0%, #1c1d21 55%, #232428 100%);
      overflow: hidden; min-height: 560px; display: flex; align-items: center; justify-content: center; }
    .vp-floor { position: absolute; left: -25%; right: -25%; bottom: -12%; height: 62%;
      perspective: 480px; pointer-events: none;
      -webkit-mask-image: linear-gradient(180deg, transparent 0, #000 45%);
      mask-image: linear-gradient(180deg, transparent 0, #000 45%); }
    .vp-grid { position: absolute; inset: 0; transform: rotateX(62deg); transform-origin: 50% 100%;
      background:
        repeating-linear-gradient(90deg, color-mix(in srgb, var(--dim) 22%, transparent) 0 1px, transparent 1px 56px),
        repeating-linear-gradient(0deg, color-mix(in srgb, var(--dim) 22%, transparent) 0 1px, transparent 1px 56px); }
    /* Blender's viewport origin lines: X red, Y green */
    .vp-grid::before { content: ''; position: absolute; left: 0; right: 0; top: 50%; height: 1px;
      background: color-mix(in srgb, var(--ax-x) 55%, transparent); }
    .vp-grid::after { content: ''; position: absolute; top: 0; bottom: 0; left: 50%; width: 1px;
      background: color-mix(in srgb, var(--ax-y) 55%, transparent); }

    .hud-corner { position: absolute; z-index: 2; }
    .hud-tl { top: 0.9rem; left: 1.1rem; display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
    .hud-tr { top: 0.9rem; right: 1.1rem; display: flex; gap: 0.55rem; align-items: center; }
    .hud-bl { bottom: 0.9rem; left: 1.1rem; }
    .hud-br { bottom: 0.9rem; right: 1.1rem; display: flex; align-items: center; gap: 0.45rem; }
    .axis { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px;
      border-radius: 50%; font-family: var(--font-mono); font-size: 0.625rem; color: #1a1b1e; font-weight: 700; }
    .axis-x { background: var(--ax-x); } .axis-y { background: var(--ax-y); } .axis-z { background: var(--ax-z); }
    .stats-hud { display: grid; grid-template-columns: auto auto; gap: 0.1rem 0.8rem; }
    .stats-hud a { color: var(--dim); transition: color 0.15s; }
    .stats-hud a:hover { color: var(--select); }
    .stats-hud .v { color: var(--text); text-align: right; font-family: var(--font-mono); font-size: 0.6875rem; }
    .ok-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ok); flex-shrink: 0; }

    .vp-center { position: relative; z-index: 3; text-align: center; padding: 4.5rem 1.25rem;
      width: 100%; max-width: 760px; }
    .vp-center h1 { font-family: var(--font-display); font-weight: 600; text-transform: uppercase;
      font-size: clamp(2.3rem, 8.5vw, 5.6rem); line-height: 0.94; letter-spacing: 0.005em; }
    .vp-center h1 .runs { color: var(--select); }
    .vp-center .sub { color: var(--dim); font-size: 1.02rem; max-width: 56ch; margin: 1.25rem auto 0; }
    .clone-row { display: flex; justify-content: center; align-items: stretch; margin-top: 1.75rem; }
    .clone-row pre { min-width: 0; background: #131417; border: 1px solid var(--border); border-right: none;
      border-radius: 4px 0 0 4px; padding: 0.6rem 0.9rem; font-family: var(--font-mono);
      font-size: 0.78rem; line-height: 1.4; overflow-x: auto; color: var(--text); text-align: left; }
    .clone-row pre .p { color: var(--dim); }
    .copy-btn { background: var(--panel-2); border: 1px solid var(--border); border-radius: 0 4px 4px 0;
      color: var(--dim); padding: 0 0.85rem; cursor: pointer; font-family: var(--font-mono);
      font-size: 0.72rem; transition: color 0.15s, border-color 0.15s; }
    .copy-btn:hover { color: var(--select); border-color: var(--select); }
    .hero-links { margin-top: 1.1rem; font-size: 0.85rem; }
    .hero-links a { color: var(--dim); font-weight: 500; margin: 0 0.7rem; transition: color 0.15s; }
    .hero-links a:hover { color: var(--select); }

    /* ---- sections as Blender panels ---- */
    main { max-width: var(--maxw); margin: 0 auto; padding: 0 1.25rem 2rem; }
    .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 6px;
      margin-top: 1.25rem; overflow: hidden; }
    .panel-head { display: flex; align-items: baseline; gap: 0.6rem; padding: 0.55rem 1.1rem;
      background: var(--panel-2); border-bottom: 1px solid var(--border); }
    .panel-head .caret { color: var(--dim); font-size: 0.6rem; align-self: center; }
    .panel-head .count { margin-left: auto; }
    .panel-body { padding: 1.5rem 1.75rem 1.75rem; }
    .panel-body > h2 { font-family: var(--font-display); font-weight: 600; text-transform: uppercase;
      font-size: clamp(1.6rem, 3.2vw, 2.2rem); line-height: 1.02; margin-bottom: 0.4rem; }
    .panel-body > .lede { color: var(--dim); max-width: 66ch; margin-bottom: 1.5rem; }
    .panel-body > .lede a { color: var(--select); }
    .panel-body > .lede a:hover { text-decoration: underline; }

    /* examples: selection-outline cards (Blender's selected-object orange) */
    .render-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .render-card { display: block; border: 1px solid var(--border); border-radius: 4px; overflow: hidden;
      background: var(--panel-2); transition: outline-color 0.12s, border-color 0.12s; outline: 2px solid transparent; outline-offset: -1px; }
    .render-card:hover { border-color: var(--select); outline-color: var(--select); }
    .render-card img { display: block; width: 100%; height: auto; aspect-ratio: 16 / 9; object-fit: cover; }
    .render-meta { display: flex; align-items: baseline; gap: 0.75rem; padding: 0.6rem 0.9rem; }
    .render-meta .name { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text); white-space: nowrap; }
    .render-meta .teach { color: var(--dim); font-size: 0.78rem; white-space: nowrap; overflow: hidden;
      text-overflow: ellipsis; }
    .panel-cta { display: inline-block; margin-top: 1.25rem; font-weight: 500; font-size: 0.9rem; color: var(--select); }
    .panel-cta:hover { text-decoration: underline; }
    /* featured subset: gallery link is the section's primary call to action */
    .cta-row { margin: -0.25rem 0 1.5rem; }
    .btn-cta { display: inline-block; background: var(--select); color: #1a1b1e; font-weight: 500;
      font-size: 0.92rem; border-radius: 4px; padding: 0.55rem 1.15rem; transition: filter 0.15s; }
    .btn-cta:hover { filter: brightness(1.12); }

    /* skills */
    .skill-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem 2.25rem; }
    .skill-row { display: flex; flex-direction: column; padding: 0.55rem 0; border-bottom: 1px solid color-mix(in srgb, var(--border) 55%, transparent); }
    .skill-row .name { font-family: var(--font-mono); font-size: 0.8rem; color: var(--select); }
    .skill-row .desc { color: var(--dim); font-size: 0.85rem; margin-top: 0.15rem; }

    /* rules */
    .rules-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .rules-table th { text-align: left; padding: 0.5rem 0.75rem 0.5rem 0; border-bottom: 1px solid var(--border); }
    .rules-table td { padding: 0.6rem 0.75rem 0.6rem 0; border-bottom: 1px solid color-mix(in srgb, var(--border) 55%, transparent);
      vertical-align: top; color: var(--dim); }
    .rules-table .r-name { color: var(--text); font-family: var(--font-mono); font-size: 0.75rem; }
    .rules-table .r-scope { font-family: var(--font-mono); font-size: 0.75rem; white-space: nowrap; }

    /* snippets */
    .chip-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .chip-grid a { font-family: var(--font-mono); font-size: 0.72rem; color: var(--dim);
      border: 1px solid var(--border); border-radius: 3px; padding: 0.28rem 0.6rem;
      transition: color 0.12s, border-color 0.12s; }
    .chip-grid a:hover { color: var(--select); border-color: var(--select); }
    .tmpl-note { color: var(--dim); font-size: 0.9rem; margin-top: 1.25rem; }
    .tmpl-note a { color: var(--select); }
    .tmpl-note a:hover { text-decoration: underline; }

    /* install */
    .steps { list-style: none; counter-reset: n; max-width: 72ch; }
    .steps li { counter-increment: n; display: flex; gap: 0.9rem; align-items: flex-start;
      padding: 0.8rem 0; border-bottom: 1px solid color-mix(in srgb, var(--border) 55%, transparent); font-size: 0.92rem; }
    .steps li::before { content: counter(n); flex-shrink: 0; width: 24px; height: 24px; border-radius: 3px;
      background: var(--panel-2); border: 1px solid var(--border); color: var(--select);
      font-family: var(--font-mono); font-size: 0.72rem; display: flex; align-items: center; justify-content: center; }
    .steps code { background: #131417; border: 1px solid var(--border); padding: 0.1rem 0.4rem;
      border-radius: 3px; font-family: var(--font-mono); font-size: 0.8em; }
    .steps strong { color: var(--text); }
    .steps li span { color: var(--dim); }

    /* ---- footer: Blender's status bar ---- */
    footer { border-top: 1px solid var(--border); background: var(--panel); margin-top: 2rem; }
    .statusbar { max-width: var(--maxw); margin: 0 auto; padding: 0.55rem 1.25rem; display: flex;
      align-items: center; gap: 1rem; flex-wrap: wrap; }
    .statusbar .right { margin-left: auto; display: flex; gap: 1rem; }
    .statusbar a { color: var(--dim); font-family: var(--font-mono); font-size: 0.6875rem;
      text-transform: uppercase; letter-spacing: 0.04em; }
    .statusbar a:hover { color: var(--select); }

    /* boot sequence: HUD fades in, stats count up (JS adds .booted) */
    @media (prefers-reduced-motion: no-preference) {
      .hud-corner { opacity: 0; transition: opacity 0.5s ease; }
      .booted .hud-corner { opacity: 1; }
      .booted .hud-tl { transition-delay: 0.1s; } .booted .hud-tr { transition-delay: 0.25s; }
      .booted .hud-bl { transition-delay: 0.4s; } .booted .hud-br { transition-delay: 0.55s; }
    }

    @media (max-width: 820px) {
      .skill-grid, .render-grid { grid-template-columns: 1fr; }
      .render-meta .teach { white-space: normal; }
    }
    @media (max-width: 640px) {
      .topnav { gap: 0.7rem; } .topnav a { font-size: 0.72rem; }
      .mode-chip { display: none; }
      .viewport { min-height: 480px; }
      .hud-bl { display: none; }
      .vp-center { padding: 3.5rem 1rem; }
      .panel-body { padding: 1.1rem 1rem 1.25rem; }
      .rules-table .r-scope { white-space: normal; }
    }
    @media (max-width: 520px) {
      .topnav li:not(.always) { display: none; }
    }
  </style>
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>

  <div class="topbar">
    <div class="topbar-inner">
      <span class="brand"><span class="brand-dot" aria-hidden="true"></span>{{ plugin.displayName }}</span>
      <span class="mode-chip" aria-hidden="true">Object Mode &#9662;</span>
      <ul class="topnav">
        {% if examples %}<li><a href="#examples">Examples</a></li>{% endif %}
        {% if skills %}<li><a href="#skills">Skills</a></li>{% endif %}
        {% if rules %}<li><a href="#rules">Rules</a></li>{% endif %}
        <li class="always"><a href="#install">Install</a></li>
        <li class="always"><a href="{{ site.links.github | default(plugin.repository) }}">GitHub</a></li>
      </ul>
    </div>
  </div>

  <!-- The viewport -->
  <div class="stage">
    <section class="viewport" id="viewport" aria-label="Overview">
      <div class="vp-floor" aria-hidden="true"><div class="vp-grid"></div></div>

      <div class="hud-corner hud-tl hud" aria-hidden="true">
        <span>Object Mode</span><span>bpy 5.1 &middot; 4.5 LTS</span>
      </div>
      <div class="hud-corner hud-tr" aria-hidden="true">
        <span class="axis axis-x">x</span><span class="axis axis-y">y</span><span class="axis axis-z">z</span>
      </div>
      <div class="hud-corner hud-bl hud stats-hud">
        {% if skill_count %}<a href="#skills">Skills</a><span class="v" data-count="{{ skill_count }}">0</span>{% endif %}
        {% if rule_count %}<a href="#rules">Rules</a><span class="v" data-count="{{ rule_count }}">0</span>{% endif %}
        {% if snippet_count %}<a href="#snippets">Snippets</a><span class="v" data-count="{{ snippet_count }}">0</span>{% endif %}
        {% if template_count %}<a href="#snippets">Templates</a><span class="v" data-count="{{ template_count }}">0</span>{% endif %}
        {% if example_count %}<a href="#examples">Examples</a><span class="v" data-count="{{ example_count }}">0</span>{% endif %}
      </div>
      <div class="hud-corner hud-br hud">
        <span class="ok-dot" aria-hidden="true"></span><span>smoke-gated on 4.5 LTS + 5.1 &middot; exit 0</span>
      </div>

      <div class="vp-center">
        <h1>Blender Python<br />that <span class="runs">actually runs</span>.</h1>
        <p class="sub">Skills, rules, snippets, and starter templates that teach Cursor and Claude Code
          the <code style="font-family: var(--font-mono); font-size: 0.9em;">bpy</code> that works —
          every pattern executed headless on Blender 4.5 LTS and 5.1 before it ships.</p>
        <div class="clone-row">
          <pre id="cloneCmd"><span class="p">$</span> git clone {{ site.links.github | default(plugin.repository) }}</pre>
          <button class="copy-btn" type="button" data-copy="git clone {{ site.links.github | default(plugin.repository) }}">copy</button>
        </div>
        <div class="hero-links">
          <a href="#examples">See the proof &darr;</a>
          <a href="gallery/">Examples gallery &rarr;</a>
        </div>
      </div>
    </section>
  </div>

  <main id="main">

  {% if examples %}
  {% set shown = featured_examples if featured_examples else examples %}
  <section class="panel" id="examples">
    <div class="panel-head">
      <span class="caret" aria-hidden="true">&#9662;</span>
      <span class="hud">Render Result</span>
      <span class="hud count">{% if featured_examples %}{{ featured_count }} of {% endif %}{{ example_count }} frames</span>
    </div>
    <div class="panel-body">
      <h2>Every render here is a CI artifact.</h2>
      <p class="lede">These aren't mockups. Each example runs headless on Blender 4.5 LTS and 5.1 in the
        smoke workflow, asserts its own correctness, and exits non-zero if the API drifted. The render is
        what the code produced.</p>
      <p class="cta-row"><a class="btn-cta" href="gallery/">Browse all {{ example_count }} examples in the gallery &rarr;</a></p>
      <div class="render-grid">
        {% for ex in shown %}
        <a class="render-card" href="gallery/{{ ex.name }}/">
          <img src="{{ ex.heroSite }}" alt="{{ ex.name }} render" loading="lazy" width="1280" height="720" />
          <div class="render-meta">
            <span class="name">{{ ex.name }}</span>
            <span class="teach">{{ ex.teaches }}</span>
          </div>
        </a>
        {% endfor %}
      </div>
      <a class="panel-cta" href="gallery/">Open the gallery — code, README, and full-size renders &rarr;</a>
    </div>
  </section>
  {% endif %}

  {% if skills %}
  <section class="panel" id="skills">
    <div class="panel-head">
      <span class="caret" aria-hidden="true">&#9662;</span>
      <span class="hud">Skills</span>
      <span class="hud count">{{ skill_count }} loaded</span>
    </div>
    <div class="panel-body">
      <h2>Workflows the AI loads by name.</h2>
      <p class="lede">Each skill is the canonical pattern for one job — operators, panels, bmesh,
        geometry nodes, slotted actions — plus the mistakes AI assistants actually make there. Where
        4.5 LTS and 5.1 diverge, both code paths are shown.</p>
      <div class="skill-grid">
        {% for skill in skills %}
        <div class="skill-row">
          <span class="name">{{ skill.category }}</span>
          <span class="desc">{{ skill.description }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {% if rules %}
  <section class="panel" id="rules">
    <div class="panel-head">
      <span class="caret" aria-hidden="true">&#9662;</span>
      <span class="hud">Rules</span>
      <span class="hud count">{{ rule_count }} active</span>
    </div>
    <div class="panel-body">
      <h2>Anti-patterns, caught before they ship.</h2>
      <p class="lede">Always-on guardrails for the failure modes that make Blender Python look right
        and run wrong: ops in loops, leaked bmesh, deprecated context dicts, per-vertex Python loops.</p>
      <table class="rules-table">
        <thead><tr><th class="hud">Rule</th><th class="hud">Scope</th><th class="hud">Flags</th></tr></thead>
        <tbody>
          {% for rule in rules %}
          <tr>
            <td class="r-name">{{ rule.slug | default(rule.name) }}</td>
            <td class="r-scope">{{ rule.scope }}</td>
            <td>{{ rule.description }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  {% if snippets %}
  <section class="panel" id="snippets">
    <div class="panel-head">
      <span class="caret" aria-hidden="true">&#9662;</span>
      <span class="hud">Snippets</span>
      <span class="hud count">{{ snippet_count }} patterns</span>
    </div>
    <div class="panel-body">
      <h2>Canonical patterns, five to fifty lines.</h2>
      <p class="lede">Standalone, paste-ready answers to the questions that come up every session:
        the right way to create and delete objects, read bulk vertex data, bind properties, bridge
        the 4.x/5.x API boundary.</p>
      <div class="chip-grid">
        {% for sn in snippets %}
        <a href="{{ site.links.github | default(plugin.repository) }}/blob/main/{{ sn.path }}">{{ sn.name }}</a>
        {% endfor %}
      </div>
      {% if templates %}
      <p class="tmpl-note">Plus {{ template_count }} starter templates:
        {% for t in templates %}<a href="{{ site.links.github | default(plugin.repository) }}/tree/main/{{ t.path }}">{{ t.name }}</a>{% if not loop.last %} and {% endif %}{% endfor %}
        — a complete Extensions-Platform add-on and a headless batch job with CI exit codes.</p>
      {% endif %}
    </div>
  </section>
  {% endif %}

  {% if site.installSteps %}
  <section class="panel" id="install">
    <div class="panel-head">
      <span class="caret" aria-hidden="true">&#9662;</span>
      <span class="hud">Install</span>
    </div>
    <div class="panel-body">
      <h2>Clone it. Point your AI at it.</h2>
      <ol class="steps">
        {% for step in site.installSteps %}
        <li><span>{{ step | safe }}</span></li>
        {% endfor %}
      </ol>
    </div>
  </section>
  {% endif %}

  </main>

  <footer>
    <div class="statusbar hud">
      <span>{{ plugin.displayName }}</span>
      <span>v{{ plugin.version }}</span>
      <span>{{ plugin.license }}</span>
      <span>built {{ build_date }}</span>
      <span style="color: var(--ok);">exit 0</span>
      <span class="right">
        <a href="{{ site.links.github | default(plugin.repository) }}/releases">Releases</a>
        <a href="{{ site.links.github | default(plugin.repository) }}">GitHub</a>
        <a href="https://tmhsdigital.github.io/Developer-Tools-Directory/">All tools</a>
      </span>
    </div>
  </footer>

  <script>
    (function () {
      // copy buttons
      document.querySelectorAll('[data-copy]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          navigator.clipboard.writeText(btn.getAttribute('data-copy')).then(function () {
            btn.textContent = 'copied';
            setTimeout(function () { btn.textContent = 'copy'; }, 1500);
          });
        });
      });

      // boot sequence: HUD fade-in + stats count-up (skipped for reduced motion)
      var vp = document.getElementById('viewport');
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var counters = document.querySelectorAll('.stats-hud .v');
      function setFinal() {
        counters.forEach(function (el) { el.textContent = el.getAttribute('data-count'); });
      }
      if (reduce) { setFinal(); } else {
        requestAnimationFrame(function () { vp.classList.add('booted'); });
        var t0 = null;
        function tick(ts) {
          if (t0 === null) t0 = ts;
          var k = Math.min((ts - t0) / 900, 1);
          var ease = 1 - Math.pow(1 - k, 3);
          counters.forEach(function (el) {
            el.textContent = Math.round(ease * parseInt(el.getAttribute('data-count'), 10));
          });
          if (k < 1) requestAnimationFrame(tick); else setFinal();
        }
        requestAnimationFrame(tick);
      }
    })();
  </script>
</body>
</html>
